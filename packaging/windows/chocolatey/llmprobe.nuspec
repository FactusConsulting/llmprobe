<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>llmprobe</id>
    <version>__VERSION__</version>
    <title>llmprobe</title>
    <authors>FactusConsulting</authors>
    <owners>FactusConsulting</owners>
    <projectUrl>https://github.com/FactusConsulting/llmprobe</projectUrl>
    <packageSourceUrl>https://github.com/FactusConsulting/llmprobe</packageSourceUrl>
    <licenseUrl>https://github.com/FactusConsulting/llmprobe/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <description>Agent-friendly CLI for probing OpenAI-compatible LLM endpoints. Health checks, model listing, latency and streaming TTFT measurement, and capability detection (vision, tools, reasoning, structured output, embeddings, rerank, audio). Composable through pipes, colored output for humans, stable JSON for agents. Ships as a single self-contained executable.</description>
    <summary>Agent-friendly CLI for probing OpenAI-compatible LLM endpoints.</summary>
    <tags>llm cli openai probe ollama vllm llama-cpp ai agent dotnet</tags>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
